# .env.example — API key configuration for demo_alignment.py
# Copy this file to .env and fill in your real keys.
# .env is git-ignored — do NOT commit real keys.

# Cerebras API keys (comma-separated, no spaces)
# Format: csk-<32-hex-chars>
# Get keys at: https://cloud.cerebras.ai
CEREBRAS_KEYS=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,csk-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# OpenAI (alternative — also supported)
# Format: sk-proj-<chars> or sk-<chars>
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (alternative — also supported)
# Format: sk-ant-api03-<chars>
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
